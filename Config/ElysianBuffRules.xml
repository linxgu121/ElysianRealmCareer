<?xml version="1.0" encoding="utf-8"?>
<ElysianBuffRules>
  <StigmataSlotRules refreshinterval="0.5">
    <StigmataRule item="elysiastigmata_top_human" slot="0" source="stigmata_slot_top" effect="elysian_slot_stigmata_top_human_effect" strength="100" />
    <StigmataRule item="elysiastigmata_top_origin" slot="0" source="stigmata_slot_top" effect="elysian_slot_stigmata_top_origin_effect" strength="100" />
    <StigmataRule item="elysiastigmata_mid_human" slot="1" source="stigmata_slot_mid" effect="elysian_slot_stigmata_mid_human_effect" strength="100" />
    <StigmataRule item="elysiastigmata_mid_origin" slot="1" source="stigmata_slot_mid" effect="elysian_slot_stigmata_mid_origin_effect" strength="100" />
    <StigmataRule item="elysiastigmata_bottom_human" slot="2" source="stigmata_slot_bottom" effect="elysian_slot_stigmata_bottom_human_effect" strength="100" />
    <StigmataRule item="elysiastigmata_bottom_origin" slot="2" source="stigmata_slot_bottom" effect="elysian_slot_stigmata_bottom_origin_effect" strength="100" />
  </StigmataSlotRules>
  <TalentAfflictionRules refreshinterval="0.5">
    <TalentAfflictionRule conditionaffliction="ablessingfromherrscherofhuman" source="talent_human_path" effect="elysian_talent_human_blessing_effect" strength="100" minstrength="0.01" />
    <TalentAfflictionRule conditionaffliction="asourcefromherrscherofhuman" source="talent_human_path" effect="elysian_talent_human_source_effect" strength="100" minstrength="0.01" />
    <TalentAfflictionRule conditionaffliction="ablessingfromherrscheroforigin" source="talent_origin_path" effect="elysian_talent_origin_blessing_effect" strength="100" minstrength="0.01" />
    <TalentAfflictionRule conditionaffliction="asourcefromherrscheroforigin" source="talent_origin_path" effect="elysian_talent_origin_source_effect" strength="100" minstrength="0.01" />
  </TalentAfflictionRules>
  <HornRules item="elysiahorn" cooldown="2.0" range="1000">
    <HornRule target="friendly" source="horn_encouragement" effect="elysiaencouragement" strength="10" />
    <HornRule target="enemyfallback" source="horn_enemy_psychosis" effect="psychosis" strength="2" />
  </HornRules>
</ElysianBuffRules>
