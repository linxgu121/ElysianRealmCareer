  <!--爱与伶之诗-->
  <Talent identifier="AnOdetoLoveandCompassion" coloroverride="1,0.34,0.85">
    <Icon texture="%ModDir%/Assets/UI/爱与伶之诗.png" sourcerect="0,0,128,128" origin="0.5,0.5" />
    <Description tag="talentdescription.AnOdetoLoveandCompassion"></Description>
    <AbilityGroupInterval interval="0.9">
      <Conditions>
        <AbilityConditionHasTalent identifier="BlessingofBeauty" truthywhen="HasTalent" />
        <AbilityConditionNoCrewDied />
      </Conditions>
      <Abilities>
        <CharacterAbilityApplyStatusEffectsToAllies allowself="true" requiresalive="true" allowclientsimulation="false">
          <StatusEffects>
            <StatusEffect type="OnAbility" target="Character" disabledeltatime="true">
              <Affliction identifier="asourcefromherrscherofhuman" amount="10.0" />
            </StatusEffect>
          </StatusEffects>
        </CharacterAbilityApplyStatusEffectsToAllies>
      </Abilities>
      <FallbackAbilities>
        <CharacterAbilityApplyStatusEffectsToAllies allowself="true" requiresalive="true" allowclientsimulation="false">
          <StatusEffects>
            <StatusEffect type="OnAbility" target="Character" disabledeltatime="true">
              <Affliction identifier="ablessingfromherrscherofhuman" amount="10.0" />
              <ReduceAffliction identifier="asourcefromherrscherofhuman" strength="10.0" />
            </StatusEffect>
          </StatusEffects>
        </CharacterAbilityApplyStatusEffectsToAllies>
      </FallbackAbilities>
    </AbilityGroupInterval>
    <AbilityGroupInterval interval="0.9">
      <Abilities>
        <CharacterAbilityApplyStatusEffectsToAllies maxdistance="1000" allowself="false">
          <StatusEffects>
            <StatusEffect type="OnAbility" target="Character" disabledeltatime="true">
              <Affliction identifier="totheflawless" amount="1.0" />
            </StatusEffect>
          </StatusEffects>
        </CharacterAbilityApplyStatusEffectsToAllies>
      </Abilities>
    </AbilityGroupInterval>
    <AbilityGroupEffect abilityeffecttype="None">
      <Abilities>
        <CharacterAbilityGiveResistance resistanceid="totheflawless" multiplier="0" />
      </Abilities>
    </AbilityGroupEffect>
  </Talent>
